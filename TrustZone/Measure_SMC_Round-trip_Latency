## 5. The Complete Code

### 5.1 latency.c

```c
#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <sys/ioctl.h>
#include <time.h>
#include <string.h>
#include <green_tee.h>

#define ITERATIONS 1000

int main() {

    // ============================================
    // SETUP
    // ============================================

    // open TEE device
    int fd = open("/dev/green_tee", O_RDWR);
    if(fd < 0) {
        printf("Error: cannot open /dev/green_tee\n");
        return 1;
    }

    // prepare smallest possible data (measure world switch, not processing)
    struct green_tee_print_data data;
    data.str = "x";
    data.len = 1;

    struct timespec start, end;
    long total_ns = 0;
    long min_ns   = 999999999;
    long max_ns   = 0;

    // ============================================
    // MEASURE PRINT (pure world switch cost)
    // ============================================

    printf("--- Measuring PRINT latency (world switch only) ---\n");
    printf("Iterations: %d\n\n", ITERATIONS);

    // warm up — throw away first call (cold cache)
    ioctl(fd, GREEN_TEE_PRINT, &data);

    for(int i = 0; i < ITERATIONS; i++) {

        clock_gettime(CLOCK_MONOTONIC, &start);  // START TIMER

        ioctl(fd, GREEN_TEE_PRINT, &data);       // COMPLETE SMC ROUND TRIP

        clock_gettime(CLOCK_MONOTONIC, &end);    // STOP TIMER

        // calculate nanoseconds for this iteration
        long ns = (end.tv_sec  - start.tv_sec)  * 1000000000L
                + (end.tv_nsec - start.tv_nsec);

        total_ns += ns;
        if(ns < min_ns) min_ns = ns;
        if(ns > max_ns) max_ns = ns;
    }

    printf("Results:\n");
    printf("  Average : %ld ns  (%ld us)\n",
           total_ns/ITERATIONS, total_ns/ITERATIONS/1000);
    printf("  Minimum : %ld ns  (%ld us)\n",
           min_ns, min_ns/1000);
    printf("  Maximum : %ld ns  (%ld us)\n",
           max_ns, max_ns/1000);
    printf("  Total   : %ld ns  (%ld ms)\n",
           total_ns, total_ns/1000000);

    // ============================================
    // MEASURE ENCRYPT (world switch + 4KB crypto)
    // ============================================

    printf("\n--- Measuring ENCRYPT latency (world switch + 4KB OTP) ---\n");

    char buff[4096] __attribute__((aligned(16)));
    memset(buff, 'A', sizeof(buff));

    long enc_total = 0;
    long enc_min   = 999999999;
    long enc_max   = 0;

    // warm up
    ioctl(fd, GREEN_TEE_ENCRYPT, buff);

    for(int i = 0; i < ITERATIONS; i++) {

        memset(buff, 'A', sizeof(buff));  // reset to plaintext each time

        clock_gettime(CLOCK_MONOTONIC, &start);  // START TIMER

        ioctl(fd, GREEN_TEE_ENCRYPT, buff);      // ENCRYPT IN SECURE WORLD

        clock_gettime(CLOCK_MONOTONIC, &end);    // STOP TIMER

        // decrypt back so next iteration has fresh plaintext
        ioctl(fd, GREEN_TEE_DECRYPT, buff);

        long ns = (end.tv_sec  - start.tv_sec)  * 1000000000L
                + (end.tv_nsec - start.tv_nsec);

        enc_total += ns;
        if(ns < enc_min) enc_min = ns;
        if(ns > enc_max) enc_max = ns;
    }

    printf("Results:\n");
    printf("  Average : %ld ns  (%ld us)\n",
           enc_total/ITERATIONS, enc_total/ITERATIONS/1000);
    printf("  Minimum : %ld ns  (%ld us)\n",
           enc_min, enc_min/1000);
    printf("  Maximum : %ld ns  (%ld us)\n",
           enc_max, enc_max/1000);

    // ============================================
    // COMPARISON AND ANALYSIS
    // ============================================

    printf("\n--- Analysis ---\n");
    printf("  PRINT   average (world switch only) : %ld us\n",
           total_ns/ITERATIONS/1000);
    printf("  ENCRYPT average (world switch+4KB)  : %ld us\n",
           enc_total/ITERATIONS/1000);
    printf("  Difference      (encryption cost)   : %ld us\n",
           enc_total/ITERATIONS/1000 - total_ns/ITERATIONS/1000);
    printf("  Throughput inside S-EL1             : %ld KB/s\n",
           4096*1000000L / (enc_total/ITERATIONS));

    printf("\n--- Estimated Breakdown of PRINT call ---\n");
    printf("  SVC  NS-EL0 → NS-EL1  : ~200  ns\n");
    printf("  SMC  NS-EL1 → EL3     : ~50   ns\n");
    printf("  NS context save        : ~500  ns\n");
    printf("  World switch to S-EL1  : ~100  ns\n");
    printf("  TEE processing (1 byte): ~200  ns\n");
    printf("  S  context save        : ~500  ns\n");
    printf("  NS context restore     : ~500  ns\n");
    printf("  Return EL3 → NS-EL1   : ~100  ns\n");
    printf("  Return NS-EL1 → NS-EL0: ~200  ns\n");
    printf("  Total estimate         : ~2350 ns (real HW)\n");
    printf("  QEMU overhead (~126x)  : ~%ld ns\n",
           total_ns/ITERATIONS);

    return 0;
}
```

